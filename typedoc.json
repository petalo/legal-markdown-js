{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": ["src/index.ts"],
  "out": "docs/api",
  "tsconfig": "tsconfig.esm.json",
  "excludePrivate": true,
  "excludeProtected": true,
  "excludeInternal": true,
  "requiredToBeDocumented": [],
  "hideGenerator": true,
  "sort": ["source-order"],
  "validation": {
    "notExported": false,
    "invalidLink": true,
    "rewrittenLink": true,
    "notDocumented": false
  }
}
